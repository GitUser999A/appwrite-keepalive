# Single project configuration
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key

# Optional: Appwrite Sites HTTP keepalive (v1.1.0+).
# Sites can pause independently of project-level pause based on site traffic
# rather than API activity. Add the deployed site URL(s) here so the keepalive
# sends an HTTP GET every run, registering a visit and keeping Sites active.
# Single URL or comma-separated list.
# APPWRITE_SITE_URLS=https://my-app.appwrite.network
# APPWRITE_SITE_URLS=https://site-a.appwrite.network,https://site-b.appwrite.network

# Multiple projects (optional, overrides single project config).
# Each entry may carry its own siteUrls (string or array).
# APPWRITE_PROJECTS='[{"endpoint":"https://cloud.appwrite.io/v1","projectId":"project1","apiKey":"key1","siteUrls":["https://a.appwrite.network"]},{"endpoint":"https://cloud.appwrite.io/v1","projectId":"project2","apiKey":"key2"}]'
